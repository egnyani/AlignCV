# Resume Matcher - Environment Variables
# Copy this file to .env and fill in your API keys

# Vercel / serverless: DOCX→PDF uses a remote service (see pipeline/pdf_converter.py).
# Without this, generate fails at PDF conversion when Word is not available.
# PDF_SERVICE_URL=https://your-render-or-other-converter.example.com

OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...paste entire JSON as one line..."}